    {
      "cell_type": "code",
      "source": [
        "#Align reads with STAR + Generate gene counts in one step\n",
        "\n",
        "# --quantMode GeneCounts → STAR counts reads per gene while aligning\n",
        "# This produces a file called aligned_ReadsPerGene.out.tab\n",
        "\n",
        "!STAR \\\n",
        "    --runThreadN 2 \\\n",
        "    --genomeDir star_index \\\n",
        "    --readFilesIn SRR519063_1.fastq SRR519063_2.fastq \\\n",
        "    --outFileNamePrefix aligned_ \\\n",
        "    --outSAMtype BAM SortedByCoordinate \\\n",
        "    --outFilterMismatchNmax 2 \\\n",
        "    --outFilterMultimapNmax 10 \\\n",
        "    --limitBAMsortRAM 2000000000 \\\n",
        "    --quantMode GeneCounts\n",
        "\n",
        "print(\"\\n Alignment and gene counting completed!\")\n",
        "!ls -lh aligned_*"
      ],
