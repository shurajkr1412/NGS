        "#Running featureCounts\n",
        "\n",
        "!featureCounts \\\n",
        "    -p \\\n",
        "    --countReadPairs \\\n",
        "    -t gene \\\n",
        "    -g ID \\\n",
        "    -a annotation.gff \\\n",
        "    -o counts.txt \\\n",
        "    -T 2 \\\n",
        "    --verbose \\\n",
        "    aligned_Aligned.sortedByCoord.out.bam\n",
